rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Regras para a Coleção de Empresas (Inquilinos/Tenants)
    // Qualquer usuário (inclusive não logado) pode ler as configurações públicas para renderizar o app do cliente.
    // Apenas o dono autenticado da empresa pode gravar ou editar suas configurações.
    match /empresas/{empresaId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == empresaId;
      allow update, delete: if request.auth != null && request.auth.uid == empresaId;
    }

    // Regras para a Coleção de Vendedores (Funcionários)
    // O próprio vendedor ou o dono da empresa correspondente pode ler/escrever.
    match /vendedores/{vendedorId} {
      allow read: if request.auth != null && (
        request.auth.uid == vendedorId || 
        resource.data.empresaId == request.auth.uid ||
        (request.auth.token.email != null && resource.data.email == request.auth.token.email)
      );
      allow create, update: if request.auth != null && (
        request.auth.uid == vendedorId || 
        request.resource.data.empresaId == request.auth.uid
      );
      allow delete: if request.auth != null && (
        resource.data.empresaId == request.auth.uid
      );
    }

    // Regras para a Coleção de Clientes
    // Qualquer cliente logado pode ler e atualizar seu próprio perfil.
    // Vendedores autenticados e donos de empresas também podem ler e atualizar perfis de clientes para gerenciar os pontos.
    match /clientes/{clienteId} {
      allow read: if request.auth != null && (
        request.auth.uid == clienteId ||
        exists(/databases/$(database)/documents/vendedores/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/empresas/$(request.auth.uid))
      );
      
      // Permitir escrita se for o próprio cliente ou se a requisição vier de um vendedor ou empresário cadastrado.
      allow write: if request.auth != null && (
        request.auth.uid == clienteId ||
        exists(/databases/$(database)/documents/vendedores/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/empresas/$(request.auth.uid))
      );
    }
  }
}
