rules_version = '2';
// Modelo multi-tenant: pontos particionados por empresa.
// Mutação de pontos/prêmios é EXCLUSIVA das Cloud Functions (Admin SDK ignora
// estas regras). O client só cria o cartão zerado e lê o que lhe pertence.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSuperAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/superadmins/$(request.auth.uid));
    }

    // Garante que os campos de billing NÃO sejam alterados via client.
    // Para cada campo: se ele NÃO está na request, tudo bem; se está, deve
    // ser idêntico ao valor já gravado no documento (ou o documento ainda não
    // tem o campo — nesse caso o client também não pode criá-lo via update).
    //
    // Padrão: !('X' in request.resource.data) || request.resource.data.X == resource.data.X
    // Quando o campo não existe no doc atual (resource.data), o segundo termo
    // nunca é true, então exigimos que ele também não apareça na request.
    function camposProtegidosIntactos() {
      let d = request.resource.data;
      let r = resource.data;
      // Para cada campo protegido:
      //   • Se ausente na request → OK (o dono pode omiti-lo).
      //   • Se presente na request E existia no doc → deve ser igual ao valor atual.
      //   • Se presente na request E NÃO existia no doc → bloqueado (client não pode criá-lo).
      return (
        (!('statusAssinatura' in d) || ('statusAssinatura' in r && d.statusAssinatura == r.statusAssinatura))
        && (!('trialEndDate' in d) || ('trialEndDate' in r && d.trialEndDate == r.trialEndDate))
        && (!('asaasCustomerId' in d) || ('asaasCustomerId' in r && d.asaasCustomerId == r.asaasCustomerId))
        && (!('asaasSubscriptionId' in d) || ('asaasSubscriptionId' in r && d.asaasSubscriptionId == r.asaasSubscriptionId))
        && (!('proximoVencimento' in d) || ('proximoVencimento' in r && d.proximoVencimento == r.proximoVencimento))
        && (!('totalPremiosEntregues' in d) || ('totalPremiosEntregues' in r && d.totalPremiosEntregues == r.totalPremiosEntregues))
      );
    }

    // --- Empresas (tenants) ---
    // Leitura pública para o app do cliente renderizar branding (cor, emoji,
    // título, prêmio, meta, link). Dívida técnica: idealmente expor só um
    // subdocumento público — ver docs/PLANO_ACAO.md §6.
    match /empresas/{empresaId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == empresaId;
      // SuperAdmin pode tudo. Dono pode atualizar, mas não pode alterar campos
      // protegidos de billing (esses campos só mudam via Admin SDK / Cloud Functions).
      allow update: if isSuperAdmin() ||
        (request.auth != null && request.auth.uid == empresaId && camposProtegidosIntactos());
      allow delete: if (request.auth != null && request.auth.uid == empresaId) || isSuperAdmin();

      // --- Cartão do cliente naquela empresa ---
      // Lê: o dono da empresa ou o próprio cliente.
      // Cria: só o próprio cliente, e SOMENTE zerado (auto-cadastro).
      // Atualiza/Deleta: ninguém via client -> só Cloud Functions (Admin SDK).
      match /clientes/{clienteId} {
        allow read: if request.auth != null &&
          (request.auth.uid == empresaId || request.auth.uid == clienteId || isSuperAdmin());
        allow create: if request.auth != null &&
          request.auth.uid == clienteId &&
          request.resource.data.pontos == 0 &&
          request.resource.data.premiosPendentes == 0;
        allow update, delete: if false;

        // Logs imutáveis (carimbos/resgates/ajustes). Só Functions gravam.
        match /logs/{logId} {
          allow read: if request.auth != null && (request.auth.uid == empresaId || isSuperAdmin());
          allow write: if false;
        }
      }
    }

    // --- Perfil do consumidor (sem pontos) ---
    // Só o próprio cliente lê/escreve. Pontos NÃO ficam aqui.
    match /clientes/{clienteId} {
      allow read, write: if request.auth != null && request.auth.uid == clienteId;
    }

    // --- Vendedores (chaveados por e-mail-slug) ---
    // Criados/editados SOMENTE pelo dono da empresa (sem self-create arbitrário).
    // Vendedor lê o próprio doc pelo e-mail do token.
    match /vendedores/{vendedorId} {
      allow read: if request.auth != null && (
        resource.data.empresaId == request.auth.uid ||
        (request.auth.token.email != null && resource.data.email == request.auth.token.email) ||
        isSuperAdmin()
      );
      allow create, update: if request.auth != null && (
        request.resource.data.empresaId == request.auth.uid ||
        isSuperAdmin()
      );
      allow delete: if request.auth != null && (
        resource.data.empresaId == request.auth.uid || isSuperAdmin()
      );
    }

    // --- Super Admin ---
    match /superadmins/{adminId} {
      allow read: if request.auth != null && request.auth.uid == adminId;
      allow write: if false;
    }

    // --- Logs do sistema ---
    match /systemLogs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if request.auth != null && (
        exists(/databases/$(database)/documents/empresas/$(request.auth.uid)) || isSuperAdmin()
      );
      allow update, delete: if false;
    }

    // --- Comunicados ---
    match /comunicados/{comunicadoId} {
      allow read: if request.auth != null && (
        exists(/databases/$(database)/documents/empresas/$(request.auth.uid)) || isSuperAdmin()
      );
      allow create, update, delete: if isSuperAdmin();
    }
  }
}
