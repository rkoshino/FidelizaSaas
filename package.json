{
  "name": "tempontinho",
  "private": true,
  "scripts": {
    "ensure-secrets": "node scripts/ensure-secrets.mjs",
    "pretest": "node scripts/ensure-secrets.mjs",
    "pretest:functions": "node scripts/ensure-secrets.mjs",
    "pretest:billing": "node scripts/ensure-secrets.mjs",
    "pretest:e2e": "node scripts/ensure-secrets.mjs",
    "test": "firebase emulators:exec --project=demo-tempontinho \"node --test test/rules.test.mjs test/functions.test.mjs test/billing.test.mjs\"",
    "test:rules": "firebase emulators:exec --project=demo-tempontinho --only firestore \"node --test test/rules.test.mjs\"",
    "test:functions": "firebase emulators:exec --project=demo-tempontinho \"node --test test/functions.test.mjs\"",
    "test:billing": "firebase emulators:exec --project=demo-tempontinho \"node --test test/billing.test.mjs\"",
    "test:e2e": "firebase emulators:exec --project=nice-dreamks-fidelidade \"node --test test/e2e.test.mjs\"",
    "test:all": "npm test && npm run test:e2e"
  },
  "dependencies": {
    "cheerio": "^1.2.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.4",
    "firebase": "^10.13.0",
    "firebase-admin": "^12.7.0",
    "playwright": "^1.61.0"
  }
}
